{
  "name": "mahjongscorerankingapi",
  "version": "1.0.0",
  "description": "Mahjong Score Ranking API server",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prettier": "prettier --write --end-of-line crlf .",
    "eslint": "eslint --cache --ext .js,.ts .",
    "eslint:fix": "eslint --cache --ext .js,.ts . --fix",
    "coverage": "c8 npm test",
    "ci": "run-p eslint coverage",
    "start": "node ./server.js",
    "test:spec": "mocha --recursive ./tests/spec/**/*.js",
    "test:others": "mocha --recursive ./tests/others/**/*.js",
    "test:database": "dotenv -e .env -- mocha --recursive ./tests/database/*.js",
    "test": "npm run build && dotenv -e .env -- mocha --recursive ./tests/",
    "init:test": "docker-compose up -d",
    "migrate:test": "dotenv -e .env -- npx prisma migrate dev",
    "build": "tsc"
  },
  "author": "Kamioda",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@json-spec/core": "^0.1.12",
    "@prisma/client": "^5.1.1",
    "crypto": "^1.0.1",
    "express": "^4.18.2",
    "randomstring": "^1.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.4.9",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "assert": "^2.0.0",
    "c8": "^8.0.1",
    "dotenv-cli": "^7.2.1",
    "eslint": "^8.46.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-mocha": "^10.1.0",
    "eslint-plugin-node": "^11.1.0",
    "expect": "^29.6.2",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.1",
    "prisma": "^5.1.1",
    "sinon": "^15.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
